{
  "name": "inkboard",
  "version": "0.3.3",
  "description": "Browser canvas for Claude Code — visual plan review, structured questions, inline annotations",
  "author": { "name": "junzhin", "url": "https://github.com/junzhin" },
  "license": "MIT",
  "skills": ["./skills/inkboard-interview/SKILL.md"],
  "commands": ["./commands/inkboard.md"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/server/dist/hooks/session-start-hook.js\" 2>&1 || true",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/server/dist/hooks/question-hook.js\" 2>/dev/null || true",
            "timeout": 120000
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/server/dist/hooks/plan-push-hook.js\" 2>/dev/null || true",
            "timeout": 1800000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/server/dist/hooks/plan-review-hook.js\" 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
